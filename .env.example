# ─────────────────────────────────────────────────────────────────────────────
# Vtopia Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Stripe (public key is safe to expose) ────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Feature Flags ────────────────────────────────────────────────────────────
VITE_ACTIVE_CITIES=Kansas City
VITE_FEATURE_WORLD_CUP=true
VITE_SINGLE_CITY_MODE=true

# ── Monetisation ─────────────────────────────────────────────────────────────
VITE_COMMISSION_RATE=0.15

# ── Affiliate IDs ────────────────────────────────────────────────────────────
VITE_BOOKING_AFFILIATE_ID=your-booking-affiliate-id
VITE_VIATOR_PARTNER_ID=your-viator-partner-id
VITE_GYG_PARTNER_ID=your-gyg-partner-id

# ── Google APIs (Places + Distance Matrix + Maps JS) ─────────────────────────
# Features degrade gracefully when not set
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── OpenWeatherMap (free tier: 1000 calls/day) ───────────────────────────────
# Weather widget hidden when not set
VITE_OPENWEATHER_API_KEY=your-openweather-api-key

# ── Foursquare (free tier: 1000 calls/day) ───────────────────────────────────
VITE_FOURSQUARE_API_KEY=your-foursquare-api-key

# ── Analytics ────────────────────────────────────────────────────────────────
VITE_SENTRY_DSN=https://your-dsn@sentry.io/your-project

# ── Server-side only (set in Supabase Edge Function secrets) ─────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# RESEND_API_KEY=re_...
