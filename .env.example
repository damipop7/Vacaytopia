# ─────────────────────────────────────────────
# vtopia — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Supabase — get these from supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJyour-anon-key-here

# Stripe — get from dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Google Maps — get from console.cloud.google.com → APIs → Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# App config — public site URL (no trailing slash). Used for OAuth redirect to /auth/callback.
# Local: http://localhost:5173  |  Production: https://www.vtopia.world
VITE_APP_URL=http://localhost:5173
VITE_COMMISSION_RATE=0.15

# Sentry — get DSN from sentry.io → your project → Settings → SDK Setup
VITE_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# City filter — KC-only mode for World Cup. Leave blank to show all cities.
# Set to a single city to hide all others from dropdowns, search, and quiz.
# TODO: re-enable post-World-Cup — clear this value to restore all cities.
VITE_ACTIVE_CITIES=Kansas City

# World Cup features — set to "true" to enable /world-cup page and KC content
VITE_FEATURE_WORLD_CUP=true

# Resend — for booking confirmation emails. Get API key from resend.com
RESEND_API_KEY=re_your-resend-api-key
