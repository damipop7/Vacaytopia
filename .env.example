# ─────────────────────────────────────────────
# Vacaytopia — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Supabase — get these from supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJyour-anon-key-here

# Stripe — get from dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Google Maps — get from console.cloud.google.com → APIs → Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# App config
VITE_APP_URL=http://localhost:5173
VITE_COMMISSION_RATE=0.15
